# ── Model provider — pick one ──────────────────────────────────────────────────
# Option A: Anthropic (recommended for production — Haiku is very cheap)
ANTHROPIC_API_KEY=your_key_here
DEFAULT_MODEL=anthropic:claude-haiku-3-5

# Option B: Groq (free tier — fast, OpenAI-compatible)
# OPENAI_API_KEY=gsk_your_groq_key_here
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# DEFAULT_MODEL=openai:llama-3.3-70b-versatile

# Option C: Local Ollama (dev only — does NOT work in production)
# DEFAULT_MODEL=ollama:llama3.2
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ── Crawler agent ──────────────────────────────────────────────────────────────
# Optional: enables Firecrawl-powered deep crawling. Falls back to httpx if unset.
FIRECRAWL_API_KEY=

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=9000
# On Railway set this to just your production domain:
CORS_ORIGINS=http://localhost:3000,https://yaminiadari.com

# ── Security ───────────────────────────────────────────────────────────────────
# Shared secret between Next.js (Vercel) and this backend (Railway).
# Generate one with: openssl rand -hex 32
# Set the SAME value as SITE_SECRET on Vercel and SITE_SECRET on Railway.
# Leave empty in local dev to disable the check.
SITE_SECRET=

# Max agent requests per IP per minute (default 20)
RATE_LIMIT_RPM=20
